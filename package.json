{
  "name": "meditation-video-studio-open",
  "version": "1.0.0",
  "private": true,
  "description": "Studio de production de vidéos de méditation guidée basé sur Remotion, n8n, OpenRouter RAG et Vercel.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "remotion studio",
    "studio": "remotion studio",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit",
    "render": "remotion render MeditationVideo public/output/meditation.mp4",
    "render:props": "tsx scripts/ingest-rag-output.ts src/data/example-input.json && remotion render MeditationVideo public/output/meditation.mp4 --props=public/output/render-props.json",
    "ingest": "tsx scripts/ingest-rag-output.ts",
    "validate": "tsx scripts/validate-timeline.ts",
    "validate:example": "tsx scripts/validate-timeline.ts src/data/example-input.json"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/media-utils": "^4.0.0",
    "@remotion/player": "^4.0.0",
    "@vercel/blob": "^0.27.0",
    "music-metadata": "^10.0.0",
    "next": "^14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
