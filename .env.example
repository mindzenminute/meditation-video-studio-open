# Token Vercel Blob (lecture/écriture) pour stocker les rendus ou assets distants.
BLOB_READ_WRITE_TOKEN=

# Clé API OpenRouter pour la génération RAG du texte de méditation.
OPENROUTER_API_KEY=

# Modèle OpenRouter recommandé pour la génération JSON structurée.
OPENROUTER_MODEL=openai/gpt-4o-mini

# Secret optionnel pour sécuriser le webhook n8n -> Vercel.
N8N_WEBHOOK_SECRET=

# Rendu Remotion
REMOTION_RENDER_CONCURRENCY=2

# Active la lecture distante de la durée audio dans les scripts de validation.
# Valeurs possibles : true / false
FETCH_AUDIO_DURATION=false

# URL de base éventuelle pour les assets audio hébergés.
AUDIO_BASE_URL=
